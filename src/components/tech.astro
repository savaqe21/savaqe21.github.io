---
import { Icon } from 'astro-icon/components';
import localTechData from '../data/tech.json';

interface Skill {
  name: string;
  icon: string;
}

interface Category {
  title: string;
  skills: Skill[];
}

const API_URL = import.meta.env.PUBLIC_API_URL;
let categories: Category[];

if (API_URL) {
  try {
    const response = await fetch(`${API_URL}/tech`);
    if (!response.ok) throw new Error('Serwer API zwrócił błąd');
    const data = await response.json();
    categories = data.categories;
  } catch (error) {
    console.error("Błąd pobierania technologii z API, ładuję dane lokalne:", error);
    categories = localTechData.categories;
  }
} else {
  categories = localTechData.categories;
}
---

<section id="tech" class="section-container overflow-hidden relative z-10">
  <div class="container mx-auto">
    
    <div class="tech-header opacity-0 mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Kompetencje
      </h2>
      <p class="text-subtext font-body text-sm max-w-md italic border-l-2 border-accent/20 pl-4">
        Zestaw technologii i narzędzi podzielony na obszary zawodowe oraz pasje.
      </p>
    </div>

    <div class="space-y-16">
      {categories.map((category: Category) => (
        <div class="space-y-6">
          <h3 class="font-mono text-[10px] uppercase tracking-[0.4em] text-accent font-bold">
            // {category.title}
          </h3>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
            {category.skills.map((skill: Skill) => (
              
              <div class="skill-card-wrapper opacity-0 group relative flex items-center gap-4 p-4 rounded-xl glass-card h-full transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_0_20px_color-mix(in srgb,var(--color-accent),transparent_90%)]">
                
                <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-xl -z-10 blur-md"></div>
                
                <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/5 transition-all duration-300 group-hover:bg-accent/10 group-hover:border-accent/30 group-hover:scale-105 group-hover:shadow-[0_0_10px_color-mix(in srgb,var(--color-accent),transparent_60%)]">
                  <Icon 
                    name={skill.icon} 
                    class="w-5 h-5 text-accent" 
                  />
                </div>
                
                <div class="flex flex-col min-w-0">
                  <span class="font-body text-[13px] font-semibold tracking-tight text-maintext group-hover:text-white transition-colors duration-300 leading-tight">
                    {skill.name}
                  </span>
                </div>

              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-header,
  .skill-card-wrapper {
    transform: translateY(15px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .tech-header.reveal,
  .skill-card-wrapper.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }

  .skill-card-wrapper {
    animation: floating-tile 6s ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
  }

  @keyframes floating-tile {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
</style>

<script>
  function initTech() {
    const cards = document.querySelectorAll('.skill-card-wrapper');
    
    cards.forEach((card) => {
      (card as HTMLElement).style.setProperty('--float-delay', `${Math.random() * 5}s`);
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          if (target.classList.contains('tech-header')) {
            target.classList.add('reveal');
          } else {
            const cardsArray = Array.from(cards);
            const index = cardsArray.indexOf(target);
            setTimeout(() => {
              target.classList.add('reveal');
            }, (index % 5) * 40);
          }
          observer.unobserve(target);
        }
      });
    }, { 
      threshold: 0.01,
      rootMargin: "0px 0px 50px 0px"
    });

    document.querySelectorAll('.tech-header, .skill-card-wrapper').forEach(el => observer.observe(el));
  }

  initTech();
  document.addEventListener('astro:after-swap', initTech);
</script>