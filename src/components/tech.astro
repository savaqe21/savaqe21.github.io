---
import { Icon } from 'astro-icon/components';
import localTechData from '../data/tech.json';

interface Skill {
  name: string;
  level: number;
  icon: string;
}

interface Category {
  title: string;
  skills: Skill[];
}

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
let categories: Category[];

try {
  if (BASE_URL) {
    const response = await fetch(`${BASE_URL}/tech`);
    const data = await response.json();
    categories = data.categories;
  } else {
    categories = localTechData.categories;
  }
} catch {
  categories = localTechData.categories;
}
---
<section id="tech" class="py-20 px-4 md:px-0">
  <div class="container mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2 flex items-center gap-4">
          <span class="text-accent">/</span> Tech Stack
        </h2>
    <div class="space-y-16">
      {categories.map((category) => (
        <div class="space-y-6">
          <h3 class="text-gray font-body text-[10px] uppercase tracking-[0.4em] ml-1">
            {category.title}
          </h3>
          
          <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7 gap-5 sm:gap-8">
            {category.skills.map((skill) => (
              <div class="group relative flex items-stretch min-h-14 rounded-xl bg-white/5 border border-white/10 hover:border-accent/40 hover:bg-white/8 transition-all duration-300">
                
                <div class="shrink-0 w-12 flex items-center justify-center rounded-l-xl bg-white/5 transition-colors group-hover:bg-accent/15">
                  <Icon name={skill.icon} class="w-7 h-7 group-hover:scale-110 transition-transform" />
                </div>
                
                <div class="flex items-center px-3 py-2 overflow-hidden w-full">
                  <span class="font-body text-white/90 text-[13px] leading-tight font-medium tracking-tight line-clamp-2">
                    {skill.name}
                  </span>
                </div>

                <div class="absolute -bottom-2 -right-1 z-10 flex gap-0 px-1 py-0.5 bg-container rounded-md border border-white/10 shadow-lg group-hover:border-accent/30 transition-all">
                  {[1, 2, 3].map((star) => (
                    <Icon 
                      name="mdi:star" 
                      class={`w-3 h-3 transition-colors duration-500 ${
                        star <= skill.level 
                          ? 'text-accent drop-shadow-[0_0_3px_var(--color-accent)]' 
                          : 'text-gray-600'
                      }`} 
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>