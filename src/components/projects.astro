---
import ProjectCard from './project-card.astro';
import projectsData from '../data/projects.json';
---

<section id="projects" class="section-container">
  <div class="container mx-auto">
    <div class="mb-16 project-header opacity-0">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
          <span class="text-accent">/</span> Projekty
      </h2>
      <p class="text-subtext font-body text-sm max-w-md italic">
        Moje realizacje techniczne, od systemów IoT po infrastrukturę i software.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projectsData.map((project) => (
        <div class="project-wrapper opacity-0">
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .project-header, .project-wrapper {
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-header.reveal, .project-wrapper.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const initProjectReveal = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          target.classList.add('reveal');
          observer.unobserve(target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.project-header, .project-wrapper').forEach(el => observer.observe(el));
  };

  const initSliders = () => {
    document.querySelectorAll('.image-slider').forEach(slider => {
      const images = slider.querySelectorAll('img');
      if (images.length <= 1) return;
      let curr = 0;
      setInterval(() => {
        images[curr].classList.replace('opacity-100', 'opacity-0');
        curr = (curr + 1) % images.length;
        images[curr].classList.replace('opacity-0', 'opacity-100');
      }, 4000);
    });
  };

  initProjectReveal();
  initSliders();
  document.addEventListener('astro:after-swap', () => {
    initProjectReveal();
    initSliders();
  });
</script>