---
import experienceData from '../data/experience.json';
---

<section id="experience" class="py-20 px-4 md:px-0 max-w-6xl mx-auto overflow-hidden">
    <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2 flex items-center gap-4">
            <span class="text-accent">/</span> Experience
        </h2>
        <p class="text-gray font-body text-sm max-w-md pb-8">
            A brief overview of my career
        </p>
    </div>

  <div class="relative">
    <div class="absolute left-4 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-0.5 bg-linear-to-b from-accent via-white/10 to-transparent"></div>

    <div class="space-y-12">
      {experienceData.map((item, index) => (
        <div class="relative grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-0">
          
          {/* Dot on the line */}
          <div class={`absolute left-4 md:left-1/2 -translate-x-1/2 top-0 w-4 h-4 rounded-full border-4 border-[#0a0a0a] z-10 
            ${index === 0 ? 'bg-accent shadow-[0_0_15px_#00ff41] animate-pulse' : 'bg-gray-600'}`}>
          </div>

          {/* Left Side Content (Odd items)*/}
          <div class={`md:px-8 ${index % 2 === 0 ? 'md:col-start-1 md:text-right' : 'md:col-start-2 opacity-0 pointer-events-none hidden md:block'}`}>
             {index % 2 === 0 && (
               <div class="bg-white/5 border border-white/10 p-6 rounded-2xl hover:border-accent/30 transition-all duration-300 group">
                <span class="text-accent font-mono text-xs tracking-widest uppercase">{item.period}</span>
                <h3 class="text-xl font-heading font-bold text-white mt-1">{item.role}</h3>
                <p class="text-gray-400 text-sm mb-4">{item.company}</p>
                <p class="text-gray-500 font-body text-sm leading-relaxed mb-4">{item.description}</p>
                <div class="flex flex-wrap gap-2 md:justify-end">
                  {item.skills.map(skill => (
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] text-gray-300 group-hover:border-accent/20">{skill}</span>
                  ))}
                </div>
               </div>
             )}
          </div>

          {/* Right Side Content (Even items)*/}
          <div class={`pl-12 md:pl-8 ${index % 2 !== 0 ? 'md:col-start-2' : 'md:col-start-1 md:hidden'}`}>
             <div class="bg-white/5 border border-white/10 p-6 rounded-2xl hover:border-accent/30 transition-all duration-300 group">
              <span class="text-accent font-mono text-xs tracking-widest uppercase">{item.period}</span>
              <h3 class="text-xl font-heading font-bold text-white mt-1">{item.role}</h3>
              <p class="text-gray-400 text-sm mb-4">{item.company}</p>
              <p class="text-gray-500 font-body text-sm leading-relaxed mb-4">{item.description}</p>
              <div class="flex flex-wrap gap-2">
                {item.skills.map(skill => (
                  <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] text-gray-300 group-hover:border-accent/20">{skill}</span>
                ))}
              </div>
             </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
