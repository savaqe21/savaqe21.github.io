---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';

---

<section id="contact" class="py-4 md:py-20 px-4 md:px-0">
  <div class="container mx-auto">
    <div class="contact-reveal opacity-0 space-y-12">
      
      <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2 flex items-center gap-4">
            <span class="text-accent">/</span> Contact Me
          </h2>
        <p class="text-gray font-body text-sm max-w-md">
          Feel free to reach out. I'm always open to discussing new projects and opportunities.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        {localData.socials.map((social) => (
          <a 
            href={social.url} 
            target="_blank" 
            class="group p-8 bg-white/5 border border-white/10 rounded-3xl hover:border-accent/40 hover:bg-accent/5 transition-all duration-300"
          >
            <Icon 
              name={social.icon} 
              class="w-10 h-10 text-accent mb-4 mx-auto group-hover:scale-110 transition-transform" 
            />
            <h3 class="text-white font-bold mb-1">{social.name}</h3>
            <p class="text-gray-400 text-xs truncate px-2">
              {social.url.replace('https://', '').replace('mailto:', '').replace('wa.me/', '+')}
            </p>
          </a>
        ))}
      </div>

      <!-- /* FOOTER */ -->
      <div class="pt-20 border-t border-white/5">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-gray-400 text-sm font-body order-2 md:order-1">
            {localData.name} © 2026
          </p>
          
          <div class="flex items-center gap-3 text-gray-400 text-xs font-body order-1 md:order-2">
            <span>Built with</span>
            <div class="flex gap-4">
              <a href="https://astro.build" target="_blank" class="hover:text-accent transition-colors flex items-center gap-1.5 group">
                <Icon name="skill-icons:astro" class="w-4 h-4 group-hover:drop-shadow-[0_0_5px_var(--color-accent)]" />
                <span>Astro</span>
              </a>
              <!-- <span class="text-gray-500">|</span>
              <a href="https://fastapi.tiangolo.com" target="_blank" class="hover:text-accent transition-colors flex items-center gap-1.5 group">
                <Icon name="skill-icons:fastapi" class="w-4 h-4 group-hover:drop-shadow-[0_0_5px_var(--color-accent)]" />
                <span>FastAPI</span> -->
              </a>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .contact-reveal {
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .contact-reveal.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const revealContact = () => {
    const section = document.querySelector('.contact-reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('reveal');
      });
    }, { threshold: 0.1 });
    if (section) observer.observe(section);
  }
  revealContact();
  document.addEventListener('astro:after-swap', revealContact);
</script>