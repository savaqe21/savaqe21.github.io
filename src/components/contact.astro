---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';
---

<section id="contact" class="section-container relative overflow-hidden stream-footer-fix z-10">
  <div class="absolute top-0 right-0 -z-10 w-64 h-64 bg-accent/5 blur-[100px] rounded-full"></div>
  
  <div class="container mx-auto">
    <div class="space-y-20">
      
      <div class="contact-header opacity-0 text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-4 flex items-center justify-center md:justify-start gap-4">
          <span class="text-accent">/</span> Kontakt
        </h2>
        <p class="text-subtext font-body text-sm max-w-lg italic">
          Zawsze chętnie pogadam o nowych wyzwaniach in IT, sieciach czy projektach security. Wybierz dogodną drogę.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {localData.socials
        .filter((social) => social.showInContact && social.url && social.url !== "#" && social.url !== "")
        .map((social) => (
          <a 
            href={social.url} 
            target="_blank" 
            class="contact-card opacity-0 group relative flex flex-col items-center p-8 glass-card rounded-2xl overflow-hidden"
          >
            <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity blur-2xl -z-10"></div>

            <div class="relative z-10 w-16 h-16 mb-6 flex items-center justify-center bg-accent/10 rounded-xl group-hover:bg-accent group-hover:rotate-[360deg] transition-all duration-700">
              <Icon 
                name={social.icon} 
                class="w-7 h-7 text-accent group-hover:text-background transition-colors duration-500" 
              />
            </div>

            <div class="relative z-10 text-center">
              <h3 class="text-maintext font-heading text-lg font-bold mb-1 group-hover:text-accent transition-colors">
                {social.name}
              </h3>
              <p class="text-accent/60 text-[9px] uppercase tracking-widest font-bold font-mono">
                {social.url.includes('mailto:') ? '// Mail' : '// Profil'}
              </p>
            </div>
            
            <div class="absolute -right-2 -bottom-2 text-accent/5 font-mono font-bold text-5xl select-none group-hover:text-accent/10 transition-colors">
              0{localData.socials.filter(s => s.showInContact).indexOf(social) + 1}
            </div>
          </a>
        ))}
      </div>

      <div class="contact-footer opacity-0 pt-16 border-t border-white/5">
        <div class="flex flex-col md:flex-row justify-between items-center md:items-start text-center md:text-left gap-12">
          
          <div class="order-2 md:order-1 flex flex-col items-center md:items-start flex-1 w-full">
            <p class="text-maintext font-heading font-bold text-2xl mb-4 hover:text-accent transition-colors">{localData.name}</p>
            
            <div class="space-y-3 mb-8 w-full">
              <div class="flex items-center justify-center md:justify-start gap-3 text-subtext text-[13px] font-body">
                <span class="text-accent/80 font-mono text-xs">#[job]</span> Junior IT Specialist at Inspiria.IT
              </div>
              <div class="flex items-center justify-center md:justify-start gap-3 text-subtext text-[13px] font-body">
                <span class="text-accent/80 font-mono text-xs">#[team]</span> Sekurak Insider | Cybersecurity Enthusiast
              </div>
              <div class="flex items-center justify-center md:justify-start gap-3 text-subtext text-[13px] font-body">
                <span class="text-accent/80 font-mono text-xs">#[edu]</span> Computer Science Student at AJP Gorzów Wielkopolski
              </div>
            </div>

            <p class="text-subtext/30 font-mono text-[9px] tracking-[0.4em] uppercase">© 2026 • Built with passion</p>
          </div>

          <div class="flex flex-col items-center md:items-end gap-3 order-1 md:order-2 shrink-0">
            <span class="text-accent text-[9px] uppercase tracking-[0.3em] font-bold font-mono">// Built With</span>
            <div class="flex items-center gap-6 px-6 py-3.5 glass-card rounded-xl shadow-xl">
              <div class="flex items-center gap-2.5 group">
                <Icon name="skill-icons:astro" class="w-5 h-5 group-hover:drop-shadow-[0_0_8px_rgba(255,125,0,0.4)] transition-all duration-300" />
                <span class="text-[11px] font-bold text-maintext tracking-widest font-mono uppercase">Astro</span>
              </div>
              <div class="w-[1px] h-5 bg-white/10"></div>
              <div class="flex items-center gap-2.5 group">
                <Icon name="skill-icons:tailwindcss-dark" class="w-5 h-5 group-hover:drop-shadow-[0_0_8px_rgba(0,180,255,0.4)] transition-all duration-300" />
                <span class="text-[11px] font-bold text-maintext tracking-widest font-mono uppercase">Tailwind</span>
              </div>
            </div>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .contact-header,
  .contact-footer,
  .contact-card {
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .contact-header.reveal,
  .contact-card.reveal,
  .contact-footer.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const revealContact = () => {
    const header = document.querySelector('.contact-header');
    const footer = document.querySelector('.contact-footer');
    const cards = document.querySelectorAll('.contact-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          if (target.classList.contains('contact-card')) {
            const index = Array.from(cards).indexOf(target);
            setTimeout(() => { target.classList.add('reveal'); }, index * 80);
          } else {
            target.classList.add('reveal');
          }
          observer.unobserve(target);
        }
      });
    }, { 
      threshold: 0.05,
      rootMargin: "0px 0px -30px 0px"
    });

    if (header) observer.observe(header);
    if (footer) observer.observe(footer);
    cards.forEach(card => observer.observe(card));
  }
  
  revealContact();
  document.addEventListener('astro:after-swap', revealContact);
</script>