---
import { Icon } from 'astro-icon/components';
import ctfData from '../data/ctf.json';
---

<section id="ctf" class="section-container overflow-hidden relative z-10">
  <div class="container mx-auto">
    
    <!-- NAGŁÓWEK SPÓJNY Z CERTYFIKATAMI -->
    <div class="ctf-header opacity-0 mb-16 text-center md:text-left">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center justify-center md:justify-start gap-4">
        <span class="text-accent">/</span> Cyber Labs
      </h2>
      <p class="text-subtext font-body text-sm max-w-md italic">
        Moja aktywność w ekosystemach Capture The Flag i laboratoriach security.
      </p>
    </div>

    <!-- UKŁAD BENTO W ZBALANSOWANEJ SKALI -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 relative">
      {ctfData.map((profile) => {
        const hasLink = profile.link && profile.link !== "#";
        const statsCount = profile.stats ? profile.stats.length : 0;
        
        let gridColsClass = 'grid-cols-3';
        if (statsCount === 1) gridColsClass = 'grid-cols-1 max-w-xs';
        if (statsCount === 2) gridColsClass = 'grid-cols-2 max-w-md';
        if (statsCount >= 4) gridColsClass = 'grid-cols-2 sm:grid-cols-4';

        return (
          <div class="ctf-node opacity-0 relative bg-gradient-to-b from-white/[0.03] to-transparent border border-white/5 rounded-2xl p-6 transition-all duration-500 group hover:border-white/10 flex flex-col justify-center overflow-hidden min-h-[190px]">
            {/* min-h i justify-center dbają o to, by elementy były idealnie wyśrodkowane w pionie, gdy jest mało danych */}
            
            {/* PRZYWRÓCONE PIĘKNE ROZŚWIETLENIE TŁA (DYNAMIC GLOW) ZA MYSZKĄ */}
            <div 
              class="absolute -inset-px opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none z-0 rounded-2xl"
              style={`background: radial-gradient(400px circle at var(--x, 0px) var(--y, 0px), color-mix(in srgb, ${profile.color || 'var(--color-accent)'}, transparent 96%), transparent 80%)`}
            ></div>

            {/* GÓRA KARTY BENTO */}
            <div class="relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-5 border-b border-white/5">
              <div class="flex items-center gap-4">
                {/* Kontener ikony w skali certyfikatów */}
                <div class="w-14 h-14 flex-shrink-0 flex items-center justify-center bg-[#141416] border border-white/10 rounded-xl group-hover:border-white/30 transition-all duration-500 shadow-2xl relative overflow-hidden">
                  {profile.icon.endsWith('.png') ? (
                    <img 
                      src={`/${profile.icon}`} 
                      alt={profile.platform} 
                      class="w-8 h-8 object-contain transition-transform duration-700 group-hover:scale-110"
                    />
                  ) : (
                    <Icon 
                      name={profile.icon} 
                      class="w-7 h-7 transition-all duration-500 group-hover:scale-110" 
                      style={profile.color ? `color: ${profile.color}` : 'color: var(--color-accent)'} 
                    />
                  )}
                </div>
                <div>
                  <h3 class="font-heading text-lg font-bold text-maintext leading-tight group-hover:text-accent transition-colors">
                    {profile.platform}
                  </h3>
                  <span class="text-[9px] font-mono tracking-widest text-subtext/40 uppercase block mt-0.5">
                    Platform Profile
                  </span>
                </div>
              </div>

              {hasLink && (
                <a 
                  href={profile.link} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="text-[10px] font-bold uppercase tracking-widest text-subtext hover:text-maintext flex items-center gap-1.5 self-start sm:self-auto px-3 py-1.5 bg-white/5 border border-white/5 rounded-lg hover:bg-white/10 hover:border-white/10 transition-all duration-300 relative z-20"
                >
                  Zweryfikuj
                  <Icon name="mdi:arrow-right" class="w-3.5 h-3.5 text-accent group-hover:translate-x-0.5 transition-transform duration-300" />
                </a>
              )}
            </div>

            {/* DÓŁ KARTY: ELASTYCZNE STATYSTYKI */}
            {statsCount > 0 && (
              <div class={`relative z-10 mt-5 grid ${gridColsClass} gap-4 items-start`}>
                {profile.stats.map((stat) => (
                  <div class="flex flex-col">
                    <span class="text-[9px] font-mono uppercase tracking-widest text-subtext/50 mb-1">
                      {stat.label}
                    </span>
                    <span class="text-maintext font-heading text-base md:text-lg font-black tracking-tight group-hover:text-accent transition-colors duration-500">
                      {stat.value}
                    </span>
                  </div>
                ))}
              </div>
            )}

            {/* Subtelny akcent kolorystyczny na krawędzi z certyfikatów */}
            <div 
              class="absolute left-0 top-1/4 bottom-1/4 w-[2px] bg-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-r"
              style={profile.color ? `background-color: ${profile.color}` : ''}
            ></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .ctf-header, .ctf-node {
    transform: translateY(25px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .ctf-header.reveal, .ctf-node.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  function setupCtfNodes() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('reveal');
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.05,
      rootMargin: "0px 0px -40px 0px" 
    });

    document.querySelectorAll('.ctf-header, .ctf-node').forEach(el => observer.observe(el));

    // Skrypt gładkiej poświaty tła (bez efektu Tilt i bez laserów)
    document.querySelectorAll('.ctf-node').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const mouseEvent = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left;
        const y = mouseEvent.clientY - rect.top;
        
        (card as HTMLElement).style.setProperty('--x', `${x}px`);
        (card as HTMLElement).style.setProperty('--y', `${y}px`);
      });
    });
  }

  setupCtfNodes();
  document.addEventListener('astro:after-swap', setupCtfNodes);
</script>