---
import { Icon } from 'astro-icon/components';
import ctfData from '../data/ctf.json';
---

<section id="ctf" class="section-container overflow-hidden relative z-10">
  <div class="container mx-auto">
    
    <div class="ctf-header opacity-0 mb-20 text-center md:text-left">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center justify-center md:justify-start gap-4">
        <span class="text-accent">/</span> Cyber Labs
      </h2>
      <p class="text-subtext font-body text-sm max-w-md italic">
        Moja aktywność w ekosystemach Capture The Flag i laboratoriach security.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 relative">
      {ctfData.map((profile) => (
        <div class="ctf-node opacity-0 relative group">
          
          <div class="absolute inset-0 pointer-events-none z-0">
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] border border-accent/5 rounded-full opacity-20 scale-75 group-hover:scale-100 transition-transform duration-700"></div>
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] h-[150%] border border-accent/5 rounded-full opacity-10 scale-75 group-hover:scale-110 transition-transform duration-1000 delay-100"></div>
          </div>

          <a href={profile.link} target="_blank" class="relative sandbox-hub z-20 flex flex-col items-center group/main">
            <div class="relative w-28 h-28 flex items-center justify-center bg-background border-2 border-accent/20 rounded-full shadow-[0_0_30px_rgba(167,139,250,0.1)] group-hover/main:border-accent group-hover/main:shadow-[0_0_50px_color-mix(in srgb,var(--color-accent),transparent_50%)] transition-all duration-500">
              <Icon 
                name={profile.icon} 
                class="w-14 h-14 transition-transform duration-500 group-hover/main:rotate-12" 
                style={profile.color ? `color: ${profile.color}` : 'color: var(--color-accent)'} 
              />
              
              <div class="absolute -bottom-4 bg-accent text-background text-[9px] font-bold font-mono uppercase px-3 py-1 rounded-md opacity-0 group-hover/main:opacity-100 transition-all translate-y-2 group-hover/main:translate-y-0 duration-300 whitespace-nowrap">
                // Otwórz profil
              </div>
            </div>
            <h3 class="mt-6 font-heading text-2xl font-bold text-maintext uppercase tracking-widest">{profile.platform}</h3>
          </a>

          <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 relative z-10">
            
            <div class="stat-bubble glass-card flex flex-col items-center p-4 rounded-xl text-center">
              <span class="text-[9px] text-accent font-bold font-mono uppercase tracking-wider mb-1">Ranga</span>
              <span class="text-maintext font-heading text-sm font-bold">{profile.rank}</span>
            </div>

            <div class="stat-bubble glass-card flex flex-col items-center p-4 rounded-xl text-center sm:-translate-y-4">
              <span class="text-[9px] text-accent font-bold font-mono uppercase tracking-wider mb-1">Punkty</span>
              <span class="text-maintext font-heading text-sm font-bold">{profile.points}</span>
            </div>

            <div class="stat-bubble glass-card flex flex-col items-center p-4 rounded-xl text-center">
              <span class="text-[9px] text-accent font-bold font-mono uppercase tracking-wider mb-1">Pwned</span>
              <span class="text-maintext font-heading text-sm font-bold">{profile.pwned}</span>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ctf-header, .ctf-node {
    transform: translateY(25px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .ctf-header.reveal, .ctf-node.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }

  /* Subtelne, powolne falowanie bąbelków ze statystykami */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Dla środkowego kafelka, uwzględniając jego bazowe przesunięcie na desktopie */
  @keyframes float-center {
    0%, 100% { transform: translateY(-16px); }
    50% { transform: translateY(-20px); }
  }

  .stat-bubble {
    animation: float 5s ease-in-out infinite;
  }
  
  /* Optymalizacja animacji pod przesunięcie środkowego elementu na dużych ekranach */
  @media (min-width: 640px) {
    .stat-bubble:nth-child(2) {
      animation: float-center 5s ease-in-out infinite;
    }
  }

  .stat-bubble:nth-child(2) { animation-delay: 1s; }
  .stat-bubble:nth-child(3) { animation-delay: 2s; }
</style>

<script>
  function setupCtfNodes() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('reveal');
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.05,
      rootMargin: "0px 0px -40px 0px" 
    });

    document.querySelectorAll('.ctf-header, .ctf-node').forEach(el => observer.observe(el));
  }

  setupCtfNodes();
  document.addEventListener('astro:after-swap', setupCtfNodes);
</script>