---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './theme-toggle.astro';

interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  { label: "Start", href: "#home", icon: `mdi:home` },
  { label: "Kariera", href: "#career", icon: `mdi:work` },
  { label: "Projekty", href: "#projects", icon: `mdi:computer` },
  { label: "Tech", href: "#tech", icon: `mdi:code-tags` },
  { label: "CTF", href: "#ctf", icon: `mdi:flag-variant` },
  { label: "Certyfikaty", href: "#certificates", icon: `mdi:certificate` },
  { label: "Kontakt", href: "#contact", icon: `mdi:message` }
];
---
<div id="theme-toggle-wrapper" class="fixed top-4 right-4 z-50 md:top-4 md:right-4 reveal-content" style="animation-delay: 700ms;">
  <ThemeToggle />
</div>

<div class="flex justify-center w-full">
  <nav id="main-nav" class="fixed left-1/2 -translate-x-1/2 z-50 transition-all duration-500 ease-in-out md:top-4 md:bottom-auto bottom-0 w-[85%] md:w-max md:px-6 md:py-2 overflow-hidden">
    <div class="container mx-auto flex justify-center items-center relative reveal-content" style="animation-delay: 700ms;">
      
      <div id="nav-blob" class="hidden md:block absolute bg-glass-bg border border-glass-border backdrop-blur-md rounded-xl transition-all duration-500 ease-out -z-10 pointer-events-none" style="will-change: left, width, height, top, border-color;"></div>

      <ul id="nav-list" class="flex w-full justify-between md:space-x-2 md:justify-center md:gap-4 gap-1 relative z-10">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="flex flex-col items-center gap-1 text-accent transition-all text-xs md:text-sm font-mono relative group px-4 py-2 rounded-lg"
            >
              <span class="md:hidden flex items-center justify-center w-5 h-5">
                <Icon name={item.icon} class="nav-icon w-full h-full text-accent/60 group-hover:text-accent transition-colors duration-300" />
              </span>
              <span class="hidden md:inline-block z-10">{item.label}</span>
              <span class="md:hidden text-[10px] font-bold font-sans mt-0.5">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</div>

<style>
  .reveal-content { opacity: 0; transform: translateY(15px); animation: revealIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes revealIn { to { opacity: 1; transform: translateY(0); } }
  nav { background-color: transparent; border-radius: 16px; transition: background-color 0.4s ease, border-color 0.4s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
  @media (min-width: 768px) { nav.scrolling { background-color: rgba(255, 255, 255, 0.01); border-color: rgba(255, 255, 255, 0.03); box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.5); } }
  nav a.active { color: var(--color-maintext) !important; font-weight: 700; }
  nav a.active .nav-icon { color: var(--color-accent) !important; transform: scale(1.1); filter: drop-shadow(0 0 6px var(--color-accent)); }
  nav li { display: flex; justify-content: center; align-items: center; flex: 1 1 0%; }
  @media (min-width: 768px) { nav li { flex: none; } }
  @media (max-width: 767px) { nav { width: 100% !important; bottom: 0; border-radius: 16px 16px 0 0; background-color: color-mix(in srgb, var(--color-background), transparent 8%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid var(--color-glass-border); } nav.scrolling { background-color: color-mix(in srgb, var(--color-background), transparent 8%); } #main-nav.nav-hidden { transform: translate3d(-50%, 110%, 0) !important; } #theme-toggle-wrapper.theme-hidden { transform: translateY(-150%) !important; } }
  nav a:not(.active):hover { color: var(--color-maintext) !important; }
</style>

<script>
  const nav = document.getElementById("main-nav");
  const blob = document.getElementById("nav-blob");
  const themeWrapper = document.getElementById("theme-toggle-wrapper");
  let lastScrollY = window.scrollY;
  let rafId: number | null = null;

  function repositionBlob() {
    if (window.innerWidth < 768 || !blob) return;
    const activeLink = nav?.querySelector("a.active") as HTMLElement;
    if (activeLink) {
      blob.style.left = `${activeLink.offsetLeft}px`;
      blob.style.top = `${activeLink.offsetTop}px`;
      blob.style.width = `${activeLink.offsetWidth}px`;
      blob.style.height = `${activeLink.offsetHeight}px`;
      blob.style.opacity = "1";
      const computedAccentColor = window.getComputedStyle(activeLink).color;
      blob.style.borderColor = computedAccentColor.replace(')', ', 0.35)').replace('rgb', 'rgba');
    } else { blob.style.opacity = "0"; }
  }

  function updateNav() {
    const currentScrollY = window.scrollY;
    if (currentScrollY > 50) nav?.classList.add("scrolling"); else nav?.classList.remove("scrolling");
    if (window.innerWidth < 768) {
      if (currentScrollY > lastScrollY && currentScrollY > 60) { nav?.classList.add("nav-hidden"); themeWrapper?.classList.add("theme-hidden"); }
      else if (lastScrollY - currentScrollY > 8 || currentScrollY < 20) { nav?.classList.remove("nav-hidden"); themeWrapper?.classList.remove("theme-hidden"); }
    }
    lastScrollY = currentScrollY;
    rafId = null;
  }
  window.addEventListener("scroll", () => { if (!rafId) rafId = requestAnimationFrame(updateNav); }, { passive: true });
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => { anchor.addEventListener("click", function (e) { e.preventDefault(); const targetId = (e.currentTarget as HTMLAnchorElement).getAttribute("href")?.substring(1) || ""; document.getElementById(targetId)?.scrollIntoView({ behavior: "smooth" }); }); });

  function spyScroll() {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("nav a[href^='#']");
    let currentActiveSectionId = "";
    let minDistance = Infinity;
    sections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      const sectionCenter = rect.top + rect.height / 2;
      const windowCenter = window.innerHeight / 2;
      const distance = Math.abs(sectionCenter - windowCenter);
      if (distance < minDistance) { minDistance = distance; currentActiveSectionId = section.getAttribute("id") || ""; }
    });
    if (window.scrollY < 100) currentActiveSectionId = "home";
    if ((window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight - 60) currentActiveSectionId = "contact";
    if (currentActiveSectionId) {
      let isChanged = false;
      navLinks.forEach((link) => {
        const isTarget = link.getAttribute("href") === `#${currentActiveSectionId}`;
        if (isTarget && !link.classList.contains('active')) { link.classList.add("active"); isChanged = true; }
        else if (!isTarget && link.classList.contains('active')) { link.classList.remove("active"); isChanged = true; }
      });
      if (isChanged) repositionBlob();
    }
  }
  window.addEventListener("scroll", spyScroll, { passive: true });
  window.addEventListener("resize", repositionBlob, { passive: true });
  document.addEventListener("DOMContentLoaded", () => { spyScroll(); repositionBlob(); });
  document.addEventListener("astro:after-swap", () => { spyScroll(); repositionBlob(); });
</script>