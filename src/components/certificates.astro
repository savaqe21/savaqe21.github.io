---
import { Icon } from 'astro-icon/components';
import certData from '../data/certificates.json';
---

<section id="certificates" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="cert-header opacity-0 mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Certyfikacje
      </h2>
      <p class="text-subtext font-body text-sm max-w-md italic">
        Oficjalne potwierdzenia moich umiejętności technicznych i wiedzy z zakresu inżynierii sieciowej.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
      {certData.map((cert) => (
        <div class="cert-card opacity-0 group relative bg-gradient-to-br from-accent/10 to-transparent border border-accent/20 rounded-2xl p-6 hover:border-accent/60 transition-all duration-500 hover:-translate-y-2 shadow-xl overflow-hidden">
          
          <div class="absolute -right-4 -bottom-4 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity duration-700">
            <Icon name={cert.icon} class="w-40 h-40" />
          </div>

          <div class="relative z-10 flex flex-col h-full">
            <div class="flex justify-between items-start mb-6">
              <div class="p-3 bg-background/60 rounded-xl border border-white/5 shadow-inner">
                <Icon name={cert.icon} class="w-10 h-10 group-hover:scale-110 transition-transform duration-500" />
              </div>
              <span class="text-[10px] font-black tracking-widest text-accent bg-accent/10 px-3 py-1 rounded-full border border-accent/20">
                {cert.date}
              </span>
            </div>

            <div class="space-y-3 flex-grow">
              <h3 class="text-maintext font-heading text-lg font-bold leading-tight group-hover:text-accent transition-colors">
                {cert.title}
              </h3>
              <p class="text-subtext font-body text-xs flex items-center gap-2">
                <span class="w-4 h-[1px] bg-accent/50"></span>
                {cert.issuer}
              </p>
              
              {cert.skills && (
                <div class="mt-4 flex flex-wrap gap-2">
                  <span class="text-[9px] uppercase tracking-wider text-textrain bg-white/5 px-2 py-1 rounded-md border border-white/5">
                    {cert.skills}
                  </span>
                </div>
              )}
            </div>

            {cert.link && cert.link !== "#" && (
              <a href={cert.link} target="_blank" class="mt-8 inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-maintext hover:text-accent transition-colors group/link">
                Weryfikuj poświadczenie
                <Icon name="mdi:external-link" class="w-3 h-3 group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform" />
              </a>
            )}
          </div>

          <div class="absolute left-0 top-1/4 bottom-1/4 w-[2px] bg-accent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cert-header, .cert-card {
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cert-header.reveal, .cert-card.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  function revealCerts() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          target.classList.add('reveal');
          observer.unobserve(target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.cert-header, .cert-card').forEach(el => observer.observe(el));
  }

  revealCerts();
  document.addEventListener('astro:after-swap', revealCerts);
</script>