---
import { Icon } from 'astro-icon/components';
const { project } = Astro.props;

const isSlider = project.images.length > 1;
---

<div class="project-card group relative bg-background border border-white/10 rounded-2xl overflow-hidden hover:border-accent/50 transition-all duration-500 shadow-xl flex flex-col h-full">
  
  <div class="aspect-video overflow-hidden relative">
    <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent z-10"></div>
    
    <div class={`w-full h-full relative ${isSlider ? 'image-slider' : ''}`}>
      {project.images.map((img: string, index: number) => (
        <img 
          src={img}
          alt={project.title}
          class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        />
      ))}
    </div>
    
    <div class="absolute top-3 right-3 flex gap-1.5 z-20">
      {project.platforms.map((p: string) => (
        <div class="p-1.5 bg-background/80 backdrop-blur-md rounded-lg border border-white/10 text-accent">
          <Icon name={`mdi:${p}`} class="w-4 h-4" />
        </div>
      ))}
    </div>
  </div>

  <div class="p-6 flex flex-col flex-grow space-y-4">
    <div class="flex justify-between items-start gap-4">
      <div class="min-w-0">
        <span class="text-accent text-[9px] uppercase tracking-[0.3em] font-black block mb-1">{project.category}</span>
        <h3 class="text-xl font-heading font-bold text-maintext truncate group-hover:text-accent transition-colors">
          {project.title}
        </h3>
      </div>
      {project.link && (
        <a href={project.link} target="_blank" class="shrink-0 p-2 rounded-lg bg-accent/10 text-accent hover:bg-accent hover:text-background transition-all duration-300">
          <Icon name="mdi:arrow-top-right" class="w-5 h-5" />
        </a>
      )}
    </div>

    <p class="text-subtext text-xs font-body leading-relaxed line-clamp-3">
      {project.description}
    </p>

    <div class="mt-auto pt-4 flex flex-wrap gap-2">
      {project.tech.map((t: string) => (
        <span class="px-2.5 py-1 rounded-md text-[9px] font-bold bg-white/5 border border-white/5 text-subtext group-hover:border-accent/30 group-hover:text-maintext transition-all">
          {t}
        </span>
      ))}
    </div>
  </div>

  <div class="h-[2px] w-0 bg-accent group-hover:w-full transition-all duration-700 ease-in-out"></div>
</div>