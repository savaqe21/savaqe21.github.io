---
interface Props {
  item: {
    period: string;
    role: string;
    company: string;
    description: string;
    skills: string[];
  };
  variant: 'mobile' | 'desktop-left' | 'desktop-right';
}

const { item, variant } = Astro.props;

const isLeft = variant === 'desktop-left';
const alignmentClass = isLeft ? "md:text-right md:items-end" : "text-left items-start";
const skillContainerClasses = `flex flex-wrap gap-2 ${isLeft ? 'md:justify-end justify-start' : 'justify-start'}`;
---

<div class={`relative flex flex-col bg-background/40 backdrop-blur-sm border border-white/5 p-6 rounded-2xl transition-all duration-500 group hover:border-accent/50 hover:bg-accent/5 shadow-xl ${alignmentClass}`}>
  
  <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl -z-10 blur-xl"></div>

  <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-accent/80 mb-2">{item.period}</span>
  
  <h3 class="text-xl font-heading font-bold text-maintext group-hover:text-accent transition-colors">
    {item.role}
  </h3>
  
  <p class="text-maintext/60 text-sm font-medium mb-4">{item.company}</p>
  
  <p class="text-subtext font-body text-xs leading-relaxed mb-6 max-w-prose">
    {item.description}
  </p>

  <div class={skillContainerClasses}>
    {item.skills.map((skill: string) => (
      <span class="rounded-lg text-[9px] font-black uppercase tracking-widest px-3 py-1.5 bg-white/5 border border-white/10 text-subtext group-hover:border-accent/30 group-hover:text-maintext transition-all">
        {skill}
      </span>
    ))}
  </div>
</div>