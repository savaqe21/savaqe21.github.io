---
interface Props {
  item: {
    period: string;
    role: string;
    company: string;
    description: string;
    skills: string[];
  };
  variant: 'mobile' | 'desktop-left' | 'desktop-right';
}

const { item, variant } = Astro.props;

const isLeft = variant === 'desktop-left';
const alignmentClass = isLeft ? "md:text-right md:items-end" : "text-left items-start";
const skillContainerClasses = `flex flex-wrap gap-2 ${isLeft ? 'md:justify-end justify-start' : 'justify-start'}`;
---

<div class={`glass-card relative flex flex-col p-6 rounded-2xl ${alignmentClass}`}>
  
  <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl -z-10 blur-xl"></div>

  <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-accent font-bold mb-2">
    [ {item.period} ]
  </span>
  
  <h3 class="text-xl font-heading font-bold text-maintext group-hover:text-accent transition-colors leading-snug">
    {item.role}
  </h3>
  
  <p class="text-subtext/80 text-xs font-mono mb-4">// {item.company}</p>
  
  <p class="text-subtext font-body text-[13px] leading-relaxed mb-6 max-w-prose">
    {item.description}
  </p>

  <div class={skillContainerClasses}>
    {item.skills.map((skill: string) => (
      <span class="rounded-md text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 bg-white/5 border border-white/5 text-subtext group-hover:border-accent/30 group-hover:text-maintext transition-all font-mono">
        {skill}
      </span>
    ))}
  </div>
</div>