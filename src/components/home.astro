---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';

interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  introHtml: string;
  resumeUrl: string;
  socials: Social[];
}

const data = localData as ProfileData;
const { name, photoUrl, introHtml, socials } = data;
---

<section id="home" class="flex flex-col items-center justify-center section-container pt-32 md:pt-40 gap-1 min-h-[85vh] text-center px-6 relative z-10">
  
  <div class="relative group mb-4 reveal-content" style="animation-delay: 100ms;">
    <div class="balloon-float w-24 h-24 md:w-28 md:h-28 rounded-full border-2 border-accent/60 overflow-hidden shadow-2xl bg-background/50 relative z-10">
      <img 
        src={photoUrl}
        alt={name}
        onerror="this.onerror=null;this.src='/placeholder.jpeg';"
        class="w-full h-full object-cover scale-110 group-hover:scale-115 transition-transform duration-500"
      />
    </div>
    <div class="balloon-float absolute top-0 left-0 w-full h-full bg-accent rounded-full blur-[60px] opacity-25 group-hover:opacity-40 transition-opacity duration-500 z-0"></div>
  </div>

  <div class="reveal-content" style="animation-delay: 200ms;">
    <p class="font-body font-medium text-accent uppercase tracking-widest text-xs mb-2">
      // Cześć, Nazywam się
    </p>
  </div>

  <div class="max-w-4xl mx-auto relative z-10 reveal-content" style="animation-delay: 300ms;">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-maintext tracking-tight mb-4">
      {name}
    </h1>
    
    <div 
      class="text-subtext font-body text-sm md:text-base leading-relaxed max-w-2xl mx-auto opacity-90 mb-6" 
      set:html={introHtml} 
    />

    <div class="font-mono text-xs md:text-sm text-accent min-h-[24px] flex items-center justify-center tracking-wide">
      <span>[+] status: </span>
      <span id="typewriter-text" class="ml-2 font-bold text-maintext"></span>
      <span class="animate-pulse-fast ml-0.5 font-bold text-accent">_</span>
    </div>
  </div>

  <div class="flex gap-8 mt-10 reveal-content" style="animation-delay: 400ms;">
    {socials.filter((social) => social.url && social.url !== "#" && social.url !== "").map((social) => (
      <a 
        href={social.url} 
        target="_blank" 
        class="group relative flex flex-col items-center justify-center transition-all duration-300 hover:scale-110"
        title={social.name}
      >
        <Icon 
          name={social.icon} 
          class="w-7 h-7 text-subtext group-hover:text-accent transition-colors duration-300" 
        />
        <span class="absolute -top-9 bg-accent/10 border border-accent/20 backdrop-blur-sm text-accent font-mono text-[9px] px-2 py-0.5 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
          {social.name}
        </span>
      </a>
    ))}
  </div>
</section>

<script is:inline>
  (function() {
    // Dodana flaga bezpośrednio jako jeden ze statusów systemu
    const phrases = [
      "Szukaj flag",
      "Są dwie",
      "Bądź uważny",
      "I dociekliwy",
      "FLAG{tak_to_vibe_coding}"

    ];
    
    let phraseIndex = 0;
    let characterIndex = 0;
    let isDeleting = false;
    let delay = 100;

    function typeEffect() {
      const target = document.getElementById("typewriter-text");
      if (!target) return;

      const currentPhrase = phrases[phraseIndex];

      // Wykrywamy czy podana fraza to flaga, aby dać jej więcej czasu i uwagi
      const isFlag = currentPhrase.startsWith("FLAG{");

      if (isDeleting) {
        target.textContent = currentPhrase.substring(0, characterIndex - 1);
        characterIndex--;
        delay = 30; // Szybsze kasowanie flagi, żeby utrzymać dynamikę
      } else {
        target.textContent = currentPhrase.substring(0, characterIndex + 1);
        delay = isFlag ? 60 : 90; // Flaga wpisuje się odrobinę szybciej i agresywniej
        characterIndex++;
      }

      if (!isDeleting && characterIndex === currentPhrase.length) {
        // Jeśli to flaga, pozwólmy użytkownikowi ją przeczytać i skopiować (pauza 4 sekundy)
        delay = isFlag ? 4000 : 2200; 
        isDeleting = true;
      } else if (isDeleting && characterIndex === 0) {
        isDeleting = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        delay = 400;
      }

      setTimeout(typeEffect, delay);
    }

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      setTimeout(typeEffect, 600);
    } else {
      document.addEventListener("DOMContentLoaded", () => setTimeout(typeEffect, 600));
    }
    document.addEventListener("astro:after-swap", () => setTimeout(typeEffect, 600));
  })();
</script>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(15px);
    animation: revealIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .balloon-float {
    will-change: transform;
    animation: floating-balloon 7s ease-in-out infinite;
  }

  @keyframes floating-balloon {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(2px, -6px) rotate(0.5deg); }
    66% { transform: translate(-2px, -3px) rotate(-0.5deg); }
  }

  @keyframes pulseFast {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-pulse-fast {
    animation: pulseFast 0.8s steps(1) infinite;
  }
</style>